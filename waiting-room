// ── Helpers ───────────────────────────────────────────────────────
function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function spin(msg) { return '<div class="spin-wrap"><div class="spin"></div>' + esc(msg) + '</div>'; }

function fitStyle(score) {
  var styles = { 1: 'badge-red', 2: 'badge-amber', 3: 'badge-yellow', 4: 'badge-green', 5: 'badge-blue' };
  return styles[score] || 'badge-gray';
}

function pendingBadgeClass(p) {
  if (!p) return 'badge-pink';
  if (p.indexOf('Ready') >= 0) return 'badge-green';
  return 'badge-pink';
}

function deadlineDays(dl) {
  if (!dl) return null;
  return Math.round((new Date(dl) - new Date()) / 86400000);
}

function deadlineBadgeHtml(dl) {
  if (!dl) return '';
  var days = deadlineDays(dl);
  var cls  = days <= 7 ? 'badge-red' : 'badge-green';
  var txt  = days < 0 ? 'Passed' : days === 0 ? 'TODAY' : days + 'd left';
  return '<span class="badge ' + cls + '">&#x23F0; ' + esc(txt) + '</span>';
}

// ── Notion REST helpers ───────────────────────────────────────────
function notionGet(path) {
  return fetch(NOTION_API + path, {
    headers: { 'Content-Type': 'application/json' }
  }).then(function(r) { return r.json(); });
}

function notionPatch(path, body) {
  return fetch(NOTION_API + path, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  }).then(function(r) { return r.json(); });
}

// ── Load Waiting Room entries from Notion ─────────────────────────
function loadEntries() {
  document.getElementById('listArea').innerHTML = spin('Loading Waiting Room...');
  document.getElementById('countBadge').textContent = 'Loading...';
  document.getElementById('refreshBtn').disabled = true;
  entries = [];

  fetch(NOTION_API + '/databases/' + JOBS_DB + '/query', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      filter: { property: 'Stage', select: { equals: '\u23f3 Waiting Room' } },
      sorts:  [{ property: 'Application Deadline', direction: 'ascending' }],
      page_size: 50
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.object === 'error') throw new Error(d.message);
    entries = (d.results || []).map(function(page, i) {
      var props = page.properties || {};
      function getText(p) {
        if (!p) return '';
        if (p.type === 'title')     return (p.title     || []).map(function(t) { return t.plain_text; }).join('');
        if (p.type === 'rich_text') return (p.rich_text || []).map(function(t) { return t.plain_text; }).join('');
        if (p.type === 'select')    return (p.select && p.select.name) || '';
        if (p.type === 'url')       return p.url || '';
        if (p.type === 'date')      return (p.date && p.date.start) || '';
        return '';
      }
      return {
        index:      i + 1,
        id:         page.id,
        url:        page.url,
        title:      getText(props['Role Title']),
        org:        getText(props['Organisation']),
        location:   getText(props['Location']),
        jobType:    getText(props['Cover Letter Template']),
        stage:      getText(props['Stage']),
        pending:    getText(props['Tasks Pending']),
        fitScore:   getText(props['CV Fit Score']),
        fitSummary: getText(props['Fit Summary']),
        deadline:   getText(props['Application Deadline']),
        notes:      getText(props['Notes']),
        // runtime state
        processing: false,
        processed:  false,
        discarded:  false,
        generatedLetter: '',
        generatedFit: null,
        statusMsg: ''
      };
    });
    renderList();
  })
  .catch(function(e) {
    document.getElementById('listArea').innerHTML = '<p class="err">Error loading entries: ' + esc(e.message) + '</p>';
    document.getElementById('countBadge').textContent = 'Error';
  })
  .finally(function() {
    document.getElementById('refreshBtn').disabled = false;
  });
}

// ── Render all cards ──────────────────────────────────────────────
function renderList() {
  var pending = entries.filter(function(e) { return !e.discarded && e.pending !== '\u2705 Ready to review'; });
  document.getElementById('countBadge').textContent = entries.length + ' job' + (entries.length !== 1 ? 's' : '');
  document.getElementById('processAllBtn').disabled = pending.length === 0;

  if (!entries.length) {
    document.getElementById('listArea').innerHTML = '<p class="empty">&#x2705; Nothing in the Waiting Room right now.</p>';
    return;
  }

  var html = '';
  for (var i = 0; i < entries.length; i++) {
    html += renderCard(entries[i]);
  }
  document.getElementById('listArea').innerHTML = html;
}

function renderCard(e) {
  var pendingCls = pendingBadgeClass(e.pending);
  var pendingTxt = e.pending || '\u23f3 Fit + Cover Letter';
  var isReady    = e.pending === '\u2705 Ready to review' || e.processed;
  var cardCls    = e.discarded ? 'card discarded' : (isReady || e.processed) ? 'card processed' : 'card';

  var fitHtml = '';
  if (e.processed && e.generatedFit) {
    var scoreNum = e.generatedFit.score || 3;
    fitHtml = '<div class="fit-row">' +
      '<span class="fit-score badge ' + fitStyle(scoreNum) + '">' + esc(e.generatedFit.label) + '</span>' +
      '<span class="fit-summary">' + esc(e.generatedFit.summary) + '</span>' +
      '</div>';
  } else if (isReady && e.fitScore) {
    fitHtml = '<div class="fit-row">' +
      '<span class="fit-score badge ' + fitStyle(parseInt(e.fitScore.charAt(1)) || 3) + '">' + esc(e.fitScore) + '</span>' +
      '<span class="fit-summary">' + esc(e.fitSummary) + '</span>' +
      '</div>';
  }

  var clHtml = '';
  if (e.processed && e.generatedLetter) {
    var preview = e.generatedLetter.slice(0, 600) + (e.generatedLetter.length > 600 ? '...' : '');
    clHtml = '<div class="section-label">Cover Letter Preview</div>' +
      '<div class="cl-preview">' + esc(preview) + '</div>';
  }

  var processBtn = '';
  if (!isReady && !e.processed) {
    processBtn = '<button class="btn-amber" onclick="processEntry(' + e.index + ')" id="procBtn' + e.index + '"' +
      (e.processing ? ' disabled' : '') + '>' +
      (e.processing ? spin('Processing...') : '&#x26A1; Process') + '</button>';
  }
  if (e.processed) {
    processBtn = '<button class="btn-blue" onclick="processEntry(' + e.index + ')" id="procBtn' + e.index + '">&#x21BA; Re-run</button>';
  }

  var moveBtn = '<button class="btn-green" onclick="moveToDrafting(' + e.index + ')" id="moveBtn' + e.index + '"' +
    ((!isReady && !e.processed) ? ' disabled title="Run processing first"' : '') + '>&#x2705; Move to Drafting</button>';

  var discardBtn = '<button class="btn-red" onclick="discard(' + e.index + ')" id="discardBtn' + e.index + '">&#x2715; Discard</button>';

  var openBtn = '<a href="' + esc(e.url) + '" target="_blank"><button class="btn-ghost">&#x2197; Open</button></a>';

  var statusHtml = e.statusMsg
    ? '<div class="status-msg ' + (e.statusMsg.ok ? 'ok' : 'err') + '">' + esc(e.statusMsg.text) + '</div>'
    : '';

  return '<div class="' + cardCls + '" id="card' + e.index + '">' +
    '<div class="card-header">' +
      '<div class="card-num">' + e.index + '</div>' +
      '<div class="card-title">' +
        '<div class="role-title">' + esc(e.title || 'Untitled Role') + '</div>' +
        '<div class="org-line">' + esc(e.org || '') + (e.location ? ' &middot; ' + esc(e.location) : '') + '</div>' +
        '<div class="card-meta">' +
          '<span class="badge badge-amber">' + esc(e.jobType || 'Other') + '</span>' +
          '<span class="badge ' + pendingCls + '">' + esc(pendingTxt) + '</span>' +
          deadlineBadgeHtml(e.deadline) +
        '</div>' +
      '</div>' +
    '</div>' +
    (fitHtml || clHtml ? '<div class="card-body">' + fitHtml + clHtml + '</div>' : '') +
    '<div class="card-actions">' +
      processBtn +
      moveBtn +
      discardBtn +
      openBtn +
    '</div>' +
    statusHtml +
    '</div>';
}

function refreshCard(idx) {
  var e = getEntry(idx);
  if (!e) return;
  var el = document.getElementById('card' + idx);
  if (el) el.outerHTML = renderCard(e);
}

function getEntry(idx) {
  for (var i = 0; i < entries.length; i++) {
    if (entries[i].index === idx) return entries[i];
  }
  return null;
}

function setStatus(e, text, isOk) {
  e.statusMsg = { text: text, ok: isOk };
  refreshCard(e.index);
}

// ── Anthropic API call ────────────────────────────────────────────
function callClaude(userMsg, system, maxTok) {
  return fetch(API, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: MODEL,
      max_tokens: maxTok || 1200,
      system: system || '',
      messages: [{ role: 'user', content: userMsg }]
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.error) throw new Error(d.error.message);
    return d.content.filter(function(b) { return b.type === 'text'; }).map(function(b) { return b.text; }).join('');
  });
}

// ── Fit assessment ────────────────────────────────────────────────
function assessFit(e) {
  var tmpl = CL_TEMPLATES[e.jobType] || CL_TEMPLATES['Other'];
  var prompt = 'Evaluate how well this CV matches the job. Return ONLY JSON with no markdown or preamble:\n' +
    '{"score":4,"label":"⭐⭐⭐⭐ 4 — Strong fit","summary":"One concise sentence explaining the score.","strengths":["strength 1","strength 2","strength 3"],"gaps":["gap 1","gap 2"]}\n\n' +
    'Score scale: 1=Poor fit (wrong field/major gaps), 2=Weak (some relevance, major gaps), 3=Moderate (decent match, notable gaps), 4=Strong (most requirements met), 5=Excellent (near-perfect match)\n' +
    'Label format must exactly match one of: "⭐ 1 — Poor fit", "⭐⭐ 2 — Weak fit", "⭐⭐⭐ 3 — Moderate fit", "⭐⭐⭐⭐ 4 — Strong fit", "⭐⭐⭐⭐⭐ 5 — Excellent fit"\n' +
    'strengths: 2-4 specific CV points that match this role\n' +
    'gaps: 1-3 requirements the CV does not fully meet (or empty array if none)\n\n' +
    'CV:\n' + CV + '\n\n' +
    'JOB:\n' +
    'Role: ' + (e.title || '') + '\n' +
    'Organisation: ' + (e.org || '') + '\n' +
    'Type: ' + (e.jobType || '') + '\n' +
    'Description: ' + (e.notes || '') + '\n' +
    'Template guidance: ' + tmpl;

  return callClaude(prompt, 'Return only a JSON object. No markdown, no preamble, no backticks.', 600)
    .then(function(raw) {
      var m = raw.match(/\{[\s\S]*\}/);
      if (!m) return { score: 3, label: '\u2b50\u2b50\u2b50 3 \u2014 Moderate fit', summary: 'Could not assess automatically.', strengths: [], gaps: [] };
      try { return JSON.parse(m[0]); }
      catch(e2) { return { score: 3, label: '\u2b50\u2b50\u2b50 3 \u2014 Moderate fit', summary: 'Could not assess automatically.', strengths: [], gaps: [] }; }
    });
}

// ── Cover letter generation ───────────────────────────────────────
function generateCoverLetter(e) {
  var tmpl = CL_TEMPLATES[e.jobType] || CL_TEMPLATES['Other'];
  var today = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

  var prompt = 'Write a complete tailored cover letter.\n\n' +
    'CV:\n' + CV + '\n\n' +
    'TEMPLATE GUIDANCE for "' + (e.jobType || 'Other') + '" roles:\n' + tmpl + '\n\n' +
    'JOB:\n' +
    'Role: ' + (e.title || '') + '\n' +
    'Organisation: ' + (e.org || '') + '\n' +
    'Location: ' + (e.location || '') + '\n' +
    'Type: ' + (e.jobType || '') + '\n' +
    'Description: ' + (e.notes || '') + '\n\n' +
    'Today: ' + today + '\n\n' +
    'Write a complete professional cover letter. Start with the date, then organisation name, then "Dear Hiring Manager,". ' +
    'Fill ALL placeholders with real content from the CV. Pick the 1-2 most relevant experiences for this specific role. ' +
    'No placeholder brackets. No editor notes. 4 paragraphs plus opening/closing. End with "Kind regards,\n\nCaden Spooner"';

  return callClaude(prompt,
    'You are an expert cover letter writer for Caden Spooner. Return only the cover letter text, no preamble.',
    1400);
}

// ── Save results back to Notion entry ────────────────────────────
function saveResultsToNotion(e, fit, letter) {
  var scoreNum   = fit.score || 3;
  var stars      = ['','\u2b50','\u2b50\u2b50','\u2b50\u2b50\u2b50','\u2b50\u2b50\u2b50\u2b50','\u2b50\u2b50\u2b50\u2b50\u2b50'][scoreNum] || '\u2b50\u2b50\u2b50';
  var scoreColor = scoreNum >= 4 ? 'green_background' : scoreNum >= 3 ? 'yellow_background' : 'red_background';
  var scoreDesc  = ['','Poor fit - significant gaps','Weak fit - some relevance but major gaps','Moderate fit - decent match with notable gaps','Strong fit - most requirements met','Excellent fit - near-perfect match'][scoreNum] || 'Moderate fit';
  var summary    = fit.summary || '';

  var props = {
    'CV Fit Score':  { select:    { name: fit.label } },
    'Fit Summary':   { rich_text: [{ type: 'text', text: { content: summary } }] },
    'Tasks Pending': { select:    { name: '\u2705 Ready to review' } }
  };

  return notionPatch('/pages/' + e.id, { properties: props })
  .then(function(d) {
    if (d.object === 'error') throw new Error(d.message);

    var blocks = [
      { type: 'divider', divider: {} },
      { type: 'heading_1', heading_1: { rich_text: [{ type: 'text', text: { content: '\uD83C\uDFAF CV Fit Assessment' } }] } },
      { type: 'callout', callout: {
        rich_text: [{ type: 'text', text: { content: stars + '  ' + fit.label + '\n' + scoreDesc } }],
        icon: { type: 'emoji', emoji: '\uD83C\uDFAF' },
        color: scoreColor
      }},
      { type: 'heading_3', heading_3: { rich_text: [{ type: 'text', text: { content: 'Summary' } }] } },
      { type: 'paragraph', paragraph: { rich_text: [{ type: 'text', text: { content: summary } }] } },
      { type: 'heading_3', heading_3: { rich_text: [{ type: 'text', text: { content: '\u2705 What matches' } }] } },
    ];

    // Strengths bullets
    var strArr = fit.strengths && fit.strengths.length ? fit.strengths : ['Review CV against role requirements'];
    for (var si = 0; si < strArr.length; si++) {
      blocks.push({ type: 'bulleted_list_item', bulleted_list_item: { rich_text: [{ type: 'text', text: { content: strArr[si] } }] } });
    }
    blocks.push({ type: 'heading_3', heading_3: { rich_text: [{ type: 'text', text: { content: '\u26a0\ufe0f Gaps to address' } }] } });

    // Gaps bullets
    var gapArr = fit.gaps && fit.gaps.length ? fit.gaps : ['No significant gaps identified'];
    for (var gi = 0; gi < gapArr.length; gi++) {
      blocks.push({ type: 'bulleted_list_item', bulleted_list_item: { rich_text: [{ type: 'text', text: { content: gapArr[gi] } }] } });
    }

    // Continue adding cover letter section blocks
    blocks.push({ type: 'divider', divider: {} });
    blocks.push({ type: 'heading_1', heading_1: { rich_text: [{ type: 'text', text: { content: '\u2709\ufe0f Cover Letter Draft' } }] } });
    blocks.push({ type: 'callout', callout: {
      rich_text: [{ type: 'text', text: { content: 'Review and personalise before sending. Replace generic phrases with specifics about this role and organisation.' } }],
      icon: { type: 'emoji', emoji: '\uD83D\uDCDD' },
      color: 'blue_background'
    }});

    // Split letter into paragraphs
    var paras = letter.split('\n\n');
    for (var i = 0; i < paras.length; i++) {
      var para = paras[i].trim();
      if (para) {
        blocks.push({ type: 'paragraph', paragraph: { rich_text: [{ type: 'text', text: { content: para } }] } });
      }
    }

    // Feedback section
    blocks.push({ type: 'divider', divider: {} });
    blocks.push({ type: 'heading_1', heading_1: { rich_text: [{ type: 'text', text: { content: '\uD83D\uDCCE Application Feedback' } }] } });
    blocks.push({ type: 'callout', callout: {
      rich_text: [{ type: 'text', text: { content: 'Fill in once you receive a response. Tick Feedback Received in the properties panel.' } }],
      icon: { type: 'emoji', emoji: '\uD83D\uDCCE' },
      color: 'gray_background'
    }});

    return fetch(NOTION_API + '/blocks/' + e.id + '/children', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ children: blocks })
    }).then(function(r) { return r.json(); });
  });
}
// ── Process a single entry ────────────────────────────────────────
function processEntry(idx) {
  var e = getEntry(idx);
  if (!e) return;
  e.processing = true;
  e.statusMsg = { text: 'Assessing fit and writing cover letter...', ok: true };
  refreshCard(idx);

  var fitResult = null;

  assessFit(e)
  .then(function(fit) {
    fitResult = fit;
    return generateCoverLetter(e);
  })
  .then(function(letter) {
    e.generatedFit    = fitResult;
    e.generatedLetter = letter;
    e.pending         = '\u2705 Ready to review';
    e.fitScore        = fitResult.label;
    e.fitSummary      = fitResult.summary;
    return saveResultsToNotion(e, fitResult, letter);
  })
  .then(function() {
    e.processed  = true;
    e.processing = false;
    e.statusMsg  = { text: '\u2705 Done — fit scored and cover letter saved to Notion.', ok: true };
    refreshCard(idx);
  })
  .catch(function(err) {
    e.processing = false;
    e.statusMsg  = { text: 'Error: ' + err.message, ok: false };
    refreshCard(idx);
  });
}

// ── Process all pending ───────────────────────────────────────────
function processAll() {
  var pending = entries.filter(function(e) {
    return !e.discarded && !e.processed && e.pending !== '\u2705 Ready to review';
  });
  if (!pending.length) return;

  var bar = document.getElementById('processBar');
  bar.style.display = '';
  document.getElementById('processAllBtn').disabled = true;

  var total = pending.length;
  var done  = 0;

  function updateBar() {
    var pct = Math.round((done / total) * 100);
    document.getElementById('pbFill').style.width  = pct + '%';
    document.getElementById('pbLabel').textContent = 'Processing ' + done + ' of ' + total + '...';
    document.getElementById('pbSub').textContent   = pending[done] ? ('Next: ' + (pending[done].title || 'Untitled')) : '';
  }

  updateBar();

  function next() {
    if (done >= total) {
      document.getElementById('pbLabel').textContent = '\u2705 All done — ' + total + ' job' + (total !== 1 ? 's' : '') + ' processed.';
      document.getElementById('pbSub').textContent   = '';
      document.getElementById('processAllBtn').disabled = false;
      return;
    }
    var e = pending[done];
    e.processing = true;
    e.statusMsg  = { text: 'Processing...', ok: true };
    refreshCard(e.index);

    var fitResult = null;
    assessFit(e)
    .then(function(fit) {
      fitResult = fit;
      return generateCoverLetter(e);
    })
    .then(function(letter) {
      e.generatedFit    = fitResult;
      e.generatedLetter = letter;
      e.pending         = '\u2705 Ready to review';
      e.fitScore        = fitResult.label;
      e.fitSummary      = fitResult.summary;
      return saveResultsToNotion(e, fitResult, letter);
    })
    .then(function() {
      e.processed  = true;
      e.processing = false;
      e.statusMsg  = { text: '\u2705 Done.', ok: true };
    })
    .catch(function(err) {
      e.processing = false;
      e.statusMsg  = { text: 'Error: ' + err.message, ok: false };
    })
    .finally(function() {
      refreshCard(e.index);
      done++;
      updateBar();
      // 1s gap between jobs to avoid API rate limits
      setTimeout(next, 1000);
    });
  }
  next();
}

// ── Move to Drafting ──────────────────────────────────────────────
function moveToDrafting(idx) {
  var e = getEntry(idx);
  if (!e) return;
  var btn = document.getElementById('moveBtn' + idx);
  if (btn) btn.disabled = true;
  setStatus(e, 'Moving to Drafting...', true);

  notionPatch('/pages/' + e.id, { properties: { 'Stage': { select: { name: 'Drafting' } } } })
  .then(function(d) {
    if (d.object === 'error') throw new Error(d.message);
    setStatus(e, '\u2705 Moved to Drafting!', true);
    setTimeout(function() {
      // Remove from list after short delay
      entries = entries.filter(function(x) { return x.index !== idx; });
      renderList();
    }, 1500);
  })
  .catch(function(err) {
    setStatus(e, 'Error: ' + err.message, false);
    if (btn) btn.disabled = false;
  });
}

// ── Discard ───────────────────────────────────────────────────────
function discard(idx) {
  var e = getEntry(idx);
  if (!e) return;
  setStatus(e, 'Discarding...', true);

  notionPatch('/pages/' + e.id, { properties: { 'Stage': { select: { name: 'Withdrawn' } } } })
  .then(function(d) {
    if (d.object === 'error') throw new Error(d.message);
    e.discarded = true;
    setStatus(e, '\u274C Discarded.', false);
    setTimeout(function() {
      entries = entries.filter(function(x) { return x.index !== idx; });
      renderList();
    }, 1000);
  })
  .catch(function(err) {
    setStatus(e, 'Error: ' + err.message, false);
  });
}

// ── Boot ──────────────────────────────────────────────────────────
loadEntries();
